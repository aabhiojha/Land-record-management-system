# Copy to `.env` and adjust before running `docker compose up`.

# --- Database ---
POSTGRES_DB=land-registry-db
DB_USERNAME=postgres
DB_PASSWORD=change-me-postgres

# --- Backend auth ---
# Must be at least 256 bits (32+ chars) for HMAC-SHA256. Use a long random value.
JWT_SECRET=please-generate-a-long-random-secret-at-least-256-bits-long

# --- Frontend ---
# Host port that serves the web app (proxies /api to the backend internally).
FRONTEND_PORT=8081
